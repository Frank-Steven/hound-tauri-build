{
  "platforms": {
    "desktop": {
      "source": ["icon-desktop.png", "icon.png"],
      "output": "src-tauri/icons"
    },
    "mac": {
      "source": ["icon-mac.png", "icon-desktop.png", "icon.png"],
      "output": "src-tauri/icons"
    },
    "win": {
      "source": ["icon-win.png", "icon-desktop.png", "icon.png"],
      "output": "src-tauri/icons"
    },
    "linux": {
      "source": ["icon-linux.png", "icon-desktop.png", "icon.png"],
      "output": "src-tauri/icons"
    },
    "android": {
      "source": ["icon-android.png", "icon.png"],
      "output": "src-tauri/gen/android/app/src/main/res"
    },
    "ios": {
      "source": ["icon-ios.png", "icon.png"],
      "output": "src-tauri/gen/ios"
    }
  },
  "tempDir": "icons/temp"
}
