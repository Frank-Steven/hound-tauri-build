{
  "name": "hound-tauri-build",
  "version": "0.1.1",
  "description": "Hound Tauri 构建系统 - 基于 TaskDAG + ConflictSet 架构的声明式任务编排与 TUI 构建工具",
  "type": "commonjs",
  "main": "index.js",
  "bin": {
    "hound-tauri-build": "bin/hound-tauri-build.js",
    "hound-tauri-clean": "bin/hound-tauri-clean.js",
    "hound-tauri-icon": "bin/hound-tauri-icon.js"
  },
  "files": [
    "index.js",
    "prepare-lib.js",
    "bin/",
    "*.cjs",
    "*.json",
    "tasks/",
    "tui-app/"
  ],
  "scripts": {},
  "keywords": [
    "hound",
    "whiteboard",
    "build",
    "task-runner",
    "dag",
    "tauri"
  ],
  "author": "Frank Steven",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/frankssteven/hound-whiteboard#readme",
  "bugs": {
    "url": "https://github.com/frankssteven/hound-whiteboard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frankssteven/hound-whiteboard.git"
  },
  "dependencies": {
    "adm-zip": "0.5.17",
    "hidefile": "3"
  },
  "peerDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "ink": "5",
    "react": "18"
  },
  "peerDependenciesMeta": {
    "ink": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
